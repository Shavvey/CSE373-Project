SQL> /**
SQL> * PROCEDURE 2: enroll_or_renew(first, last, email): if a person with the
SQL> * given first name, last name, and email address is a member in good
SQL> * standing, then extend the membership by one year; if the membership
SQL> * has expired, then set the expiration date to one year from today.
SQL> * If no such person is found among the past or present members, then
SQL> * enroll this person as a new member.
SQL> **/
SQL> 
SQL> -- Helper function
SQL> CREATE OR REPLACE PROCEDURE get_standing_and_expiry
  2    (first IN member.fname%type,
  3  	last IN member.lname%type,
  4  	mem_email IN member.email%type,
  5  	mem_standing OUT member.standing%type,
  6  	status OUT boolean, -- NOTE: Check if record exists
  7  	is_expired OUT boolean)
  8  IS
  9    mem_expr member.member_expr%type;
 10  BEGIN
 11    SELECT member_expr, standing INTO mem_expr, mem_standing
 12    FROM member m
 13    WHERE first = fname
 14    AND last = lname
 15    AND mem_email = email;
 16    status := true;
 17    IF TRUNC(mem_expr) - TRUNC(SYSDATE) < 0 THEN
 18  	 is_expired := true;
 19    ELSE
 20  	 is_expired := false;
 21    END IF;
 22  EXCEPTION
 23    WHEN no_data_found THEN
 24  	 status := false;
 25  END;
 26  /

Procedure created.

SQL> show errors
No errors.
SQL> 
SQL> CREATE OR REPLACE PROCEDURE enroll_or_renew
  2    (first IN member.fname%type,
  3  	last IN member.lname%type,
  4  	mem_email IN member.email%type)
  5  IS
  6    status boolean;
  7    is_expired boolean;
  8    mem_standing member.standing%type;
  9  BEGIN
 10    get_standing_and_expiry(first, last, mem_email, mem_standing, status, is_expired);
 11    IF status THEN
 12  	 IF is_expired AND mem_standing = 'good' THEN
 13  	   UPDATE member m
 14  	   -- Extend membership one year from today
 15  	   SET member_expr = ADD_MONTHS(SYSDATE, 12)
 16  	   WHERE first = fname
 17  	   AND last = lname
 18  	   AND mem_email = email;
 19  	 END IF;
 20  	 IF NOT is_expired AND mem_standing = 'good' THEN
 21  	   UPDATE member m
 22  	   SET member_expr = ADD_MONTHS(member_expr, 12)
 23  	   WHERE first = fname
 24  	   AND last = lname
 25  	   AND mem_email = email;
 26  	 END IF;
 27    ELSE
 28  	 -- If entry doesn't already exists, add it
 29  	 IF NOT status THEN
 30  	   INSERT INTO member (member_id, fname, lname,
 31  	     email, member_expr,
 32  	     date_joined, date_of_record, standing)
 33  	   VALUES(id_seq.NEXTVAL, first, last, mem_email,
 34  	     ADD_MONTHS(SYSDATE, 12),
 35  	     SYSDATE, SYSDATE, 'good');
 36  	 END IF;
 37    END IF;
 38  END;
 39  /

Procedure created.

SQL> show errors
No errors.
