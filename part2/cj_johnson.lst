SQL> /**
SQL> * QUERY 4: if either two members have the same first name, last name, and email
SQL> * address, or a non-member and a member share those three items, then
SQL> * print those three items for each pair; add a string BOTH MEMBERS
SQL> * in the first case and ONE NON-MEMBER in the other. The items for
SQL> * BOTH-MEMBERS should appear first ordered by first name followed
SQL> * by the rest ordered similarly.
SQL> **/
SQL> 
SQL> SELECT fname, lname, email, 'ONE MEMBER'
  2  FROM member m
  3  WHERE EXISTS
  4    (SELECT *
  5    FROM non_member nm
  6    WHERE nm.fname = m.fname
  7    AND nm.lname = m.lname
  8    AND nm.email = m.email
  9    )
 10  UNION ALL
 11  SELECT fname, lname, email, 'BOTH MEMBER'
 12  FROM member m1
 13  WHERE EXISTS
 14    (SELECT *
 15    FROM member m2
 16    WHERE m1.fname = m2.fname
 17    AND m1.lname = m2.lname
 18    AND m1.email = m2.email
 19    AND m1.member_id != m2.member_id
 20    );

