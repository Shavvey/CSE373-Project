SQL> /**
SQL> * QUERY 1: Display the following group name and number of members:
SQL> * (i) parent but not educator, (ii) educator but not parent,
SQL> * and (iii) both a parent and an educator
SQL> **/
SQL> 
SQL> SELECT COUNT(*) AS "Parent But Not Educator Count" from (
  2    SELECT member_id from parent
  3    MINUS -- set difference
  4    SELECT member_id from educator
  5  );

Parent But Not Educator Count                                                   
-----------------------------                                                   
                            2                                                   

SQL> 
SQL> SELECT COUNT(*) AS "Educator But Not Parent Count" from (
  2    SELECT member_id from educator
  3    MINUS -- set difference
  4    SELECT member_id from parent
  5  );

Educator But Not Parent Count                                                   
-----------------------------                                                   
                            5                                                   

SQL> 
SQL> SELECT COUNT(*) AS "Both Parent and Eduator Count" from (
  2    SELECT member_id from member
  3    INTERSECT
  4    SELECT member_id from parent
  5    INTERSECT
  6    SELECT member_id from educator
  7  );

Both Parent and Eduator Count                                                   
-----------------------------                                                   
                            2                                                   

