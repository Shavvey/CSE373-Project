SQL> /*
SQL> * PROCEDURE 3: flag_graduated_children( ): find members all of whose children
SQL> * should have graduated by now; list their ID, first and last name.
SQL> **/
SQL> 
SQL> -- Helper function
SQL> CREATE OR REPLACE PROCEDURE get_child_dor
  2    (mem_id IN member.member_id%type,
  3  	status OUT boolean,
  4  	is_graduated OUT boolean)
  5  IS
  6    CURSOR child_cursor IS SELECT member_id, date_of_record FROM member_child;
  7    dor member_child.date_of_record%type;
  8    child_mem_id member_child.member_id%type;
  9  BEGIN
 10    is_graduated := false;
 11    status := false;
 12    OPEN child_cursor;
 13    LOOP
 14  	 FETCH child_cursor into child_mem_id, dor;
 15  	 IF TRUNC(MONTHS_BETWEEN(SYSDATE, dor)/12) >= 4
 16  	   AND child_mem_id = mem_id THEN
 17  	   is_graduated := true;
 18  	   status := true;
 19  	   EXIT;
 20  	 END IF;
 21  	 EXIT WHEN child_cursor%NOTFOUND;
 22    END LOOP;
 23    CLOSE child_cursor;
 24  END;
 25  /

Procedure created.

SQL> show errors
No errors.
SQL> 
SQL> CREATE OR REPLACE PROCEDURE flag_graduated_children
  2  IS
  3    is_graduated BOOLEAN;
  4    status BOOLEAN;
  5    first_name member.fname%type;
  6    last_name member.lname%type;
  7    mem_id member.member_id%type;
  8  BEGIN
  9    is_graduated := false;
 10    status := false;
 11    SELECT member_id, fname, lname INTO mem_id, first_name, last_name
 12    FROM member;
 13    get_child_dor(mem_id, status, is_graduated);
 14    IF status AND is_graduated THEN
 15  	 dbms_output.put_line('Flaged member for child grad: ' || mem_id || ', ' || first_name|| ', ' || last_name);
 16    END IF;
 17  EXCEPTION
 18    -- NOTE: Hacky way to ingore duplicates
 19    WHEN too_many_rows THEN
 20  	 dbms_output.put_line('Flag member for child grad: ' || mem_id || ', ' || first_name|| ', ' || last_name);
 21  END;
 22  
 23  /

