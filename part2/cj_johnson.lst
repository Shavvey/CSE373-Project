SQL> /**
SQL> * PROCEDURE 1: find_id_name(last): display the ID, first and last name of all members
SQL> * (regardless of their membership standing) whose last name contains
SQL> * last (the parameter!) as a substring. Print a message if there is
SQL> * no such member.
SQL> **/
SQL> -- Help function
SQL> CREATE OR REPLACE PROCEDURE get_lname
  2    (last IN member.lname%type,
  3  	mem_id OUT member.member_id%type,
  4  	first_name OUT member.fname %type,
  5  	last_name OUT member.lname%type,
  6  	status OUT boolean)
  7  IS
  8  BEGIN
  9    SELECT member_id, fname, lname INTO mem_id, first_name, last_name
 10    FROM member WHERE lname = last;
 11    status := true;
 12  EXCEPTION
 13    WHEN no_data_found THEN
 14  	 status := false;
 15  END;
 16  /

Procedure created.

SQL> show errors
No errors.
SQL> 
SQL> CREATE OR REPLACE PROCEDURE find_id_name
  2    (last IN member.lname%type)
  3  IS
  4    first_name VARCHAR(20);
  5    last_name VARCHAR(20);
  6    mem_id number;
  7    status boolean;
  8  BEGIN
  9    get_lname(last, mem_id, first_name, last_name, status);
 10    IF status THEN
 11  	 dbms_output.put_line('Member found: ' || mem_id || ',' || last_name || ',' || first_name);
 12    ELSE
 13  	 dbms_output.put_line('Member not found ');
 14    END IF;
 15  END;
 16  /

Procedure created.

