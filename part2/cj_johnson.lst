SQL> -- STEP 1: Create relational schema
SQL> @schema
SQL> /**
SQL> * CSE373 - Introduction to Databases - Project
SQL> * ============================================
SQL> * Name: Cole Johnson
SQL> * Due Date: 5/2/2026
SQL> *
SQL> * I certify that this assignment has been
SQL> * completed by myself.
SQL> **/
SQL> 
SQL> create table member(
  2    member_id    DECIMAL(7,0) NOT NULL, -- 4 digits, no digits after the decimal place
  3    fname	    VARCHAR(20) NOT NULL,
  4    lname	    VARCHAR(20) NOT NULL,
  5    email	    VARCHAR(30) NOT NULL,
  6    zip	    DECIMAL(5,0) NOT NULL, -- NOTE: VARCHAR might also be acceptable
  7    street	    VARCHAR(20) NOT NULL,
  8    city	    VARCHAR(20) NOT NULL,
  9    member_expr  DATE NOT NULL, -- NOTE: When the member's expiration date is
 10    date_joined  DATE NOT NULL,
 11    date_of_record DATE NOT NULL, -- NOTE: When we first learned this info
 12    -- NOTE: Tracks the standing of each member
 13    standing     VARCHAR(20) NOT NULL CHECK (standing in ('good', 'poor')),
 14    CONSTRAINT member_pk PRIMARY KEY (member_id), -- primary key constraint
 15    CONSTRAINT has_member_id_prefix CHECK (member_id LIKE '900%') -- make sure each ID has 900 prefix
 16    -- NOTE: last name and first can also be used for identification, put ID is preferred and designated as key
 17  );

Table created.

SQL> 
SQL> create table school(
  2    school_name	VARCHAR(20) NOT NULL,
  3    principle_lname	VARCHAR(20) NOT NULL,
  4    principle_fname	VARCHAR(20) NOT NULL,
  5    is_middleschool	CHAR(1) NOT NULL CHECK (is_middleschool in ('y', 'n')),
  6    is_highschool	CHAR(1) NOT NULL CHECK (is_highschool in ('y', 'n')),
  7    CONSTRAINT school_pk PRIMARY KEY (school_name) -- school name is unique
  8  );

Table created.

SQL> 
SQL> -- Tracks volunteered members to be a school liason
SQL> create table volunteer_liason(
  2    member_id   DECIMAL(7,0) NOT NULL,
  3    school_name VARCHAR(20) NOT NULL,
  4    CONSTRAINT volunteer_liason_member_fk FOREIGN KEY (member_id) REFERENCES member(member_id),
  5    CONSTRAINT volunteer_liason_school_fk FOREIGN KEY (school_name) REFERENCES school(school_name),
  6    CONSTRAINT volunteer_liason_pk PRIMARY KEY (member_id, school_name)
  7  );

Table created.

SQL> 
SQL> -- Tracks appointed member to be a school liason
SQL> -- NOTE: From ER diagram, this relationship has all partial participation
SQL> -- so we need to invest in a separate a
SQL> create table liason(
  2    member_id   DECIMAL(7,0) NOT NULL,
  3    school_name VARCHAR(20) NOT NULL,
  4    CONSTRAINT liason_member_fk FOREIGN KEY (member_id) REFERENCES member(member_id),
  5    CONSTRAINT liason_school_fk FOREIGN KEY (school_name) REFERENCES school(school_name),
  6    CONSTRAINT liason_pk PRIMARY KEY (member_id),
  7    CONSTRAINT school_name_unique UNIQUE(school_name) -- NOTE: constraint is to limit multiple associations
  8  );

Table created.

SQL> 
SQL> create table parent(
  2    member_id DECIMAL(7,0) NOT NULL, -- parent id references foregin key of memeber
  3    CONSTRAINT parent_pk PRIMARY KEY (member_id),
  4    CONSTRAINT parent_member_fk FOREIGN KEY (member_id) REFERENCES member(member_id)
  5  	 INITIALLY DEFERRED DEFERRABLE
  6  );

Table created.

SQL> 
SQL> 
SQL> create table member_child(
  2    member_id      DECIMAL(7,0) NOT NULL,
  3    child_fname    VARCHAR(20) NOT NULL,
  4    child_lname    VARCHAR(20) NOT NULL,
  5    school_name    VARCHAR(20) NOT NULL,
  6    date_of_record DATE NOT NULL, -- NOTE: When this info was learned and put inside database
  7    CONSTRAINT member_child_pk PRIMARY KEY(child_fname, child_lname, member_id),
  8    CONSTRAINT member_child_member_fk FOREIGN KEY (member_id) REFERENCES parent(member_id)
  9  	 INITIALLY DEFERRED DEFERRABLE,
 10    CONSTRAINT member_child_school_fk FOREIGN KEY (school_name) REFERENCES school(school_name)
 11  	 INITIALLY DEFERRED DEFERRABLE
 12  );

Table created.

SQL> 
SQL> 
SQL> /**
SQL> * Educator Relation
SQL> *
SQL> * == NOTES AND REASONING FOR THIS RELATIONAL SCHEMA ==
SQL> * I feel like collapsing the teacher and admin subclasses into
SQL> * single relation needs some further justification, since
SQL> * there are a other ways we could represent these entities.
SQL> *
SQL> * The main reason is decided to collapse the subclassing entities
SQL> * was to improve queries involving all educator, avoiding many joins
SQL> * on tables with few attributes.
SQL> */
SQL> create table educator(
  2    member_id   DECIMAL(7,0) NOT NULL, -- parent id references foregin key of memeber
  3    is_teacher  CHAR(1) NOT NULL CHECK (is_teacher in ('y', 'n')), -- NOTE: collasping educator subclasses via boolean flags
  4    is_admin    CHAR(1) NOT NULL CHECK (is_admin in ('y', 'n')),
  5    school_name VARCHAR(20) NOT NULL,
  6    -- NOTE: Field is for educators that either teach or taught math or science, look at constraints to see how I enforce this
  7    teach_sci_or_math VARCHAR(20) NOT NULL CHECK (teach_sci_or_math in ('science', 'math', 'both', 'none')),
  8    CONSTRAINT educator_pk PRIMARY KEY (member_id),
  9    CONSTRAINT educator_member_fk FOREIGN KEY (member_id) REFERENCES member(member_id),
 10    CONSTRAINT educator_school_fk FOREIGN KEY (school_name) REFERENCES school(school_name),
 11    CONSTRAINT admin_teaher_disjoint_and_total_coverage CHECK ((is_teacher = 'n' AND is_admin = 'y')
 12  	 OR (is_teacher = 'y' AND is_admin = 'n')), -- NOTE: each educator instance must either be admin or teacher, cannot overlap and cannot be a different instance
 13    -- NOTE: administrators do not teach subjects, must be none
 14    CONSTRAINT admin_does_not_teach CHECK
 15    ((is_admin = 'y' AND teach_sci_or_math = 'none')
 16  	 OR is_teacher = 'y')
 17  );

Table created.

SQL> 
SQL> 
SQL> -- TODO: Create integrity constraint that says only one role can be occupied at a time
SQL> create table board_member(
  2    member_id DECIMAL(7,0) NOT NULL, -- parent id references foregin key of memeber
  3    role	 VARCHAR(13) CHECK (role in ('president', 'secretary', 'treasurer', 'data manager')),
  4    CONSTRAINT board_mem_pk PRIMARY KEY (member_id),
  5    CONSTRAINT board_mem_member_fk FOREIGN KEY (member_id) REFERENCES member(member_id),
  6    CONSTRAINT board_mem_role_unique UNIQUE(role) -- NOTE: ensures there is only one board member assigned to a role
  7  );

Table created.

SQL> 
SQL> create table meeting(
  2    meet_location VARCHAR(20) NOT NULL,
  3    meet_date     VARCHAR(20) NOT NULL,
  4    member_id     DECIMAL(7,0) NOT NULL,
  5    CONSTRAINT meeting_pk PRIMARY KEY (meet_location, meet_date),
  6    CONSTRAINT meeting_board_mem_fk FOREIGN KEY (member_id) REFERENCES board_member(member_id)
  7  );

Table created.

SQL> 
SQL> create table non_member(
  2    fname	      VARCHAR(20) NOT NULL, -- NOTE: Maybe I should prefix this to avoid unwanted natural joins
  3    lname	      VARCHAR(20) NOT NULL,
  4    email	      VARCHAR(20) NOT NULL,
  5    zip	      DECIMAL(5,0) NOT NULL, -- NOTE: VARCHAR might also be acceptable, but decimal is easier for comparison
  6    street	      VARCHAR(20) NOT NULL,
  7    city	      VARCHAR(20) NOT NULL,
  8    date_of_record DATE NOT NULL, -- NOTE: When we first learned this info
  9    CONSTRAINT non_member_pk PRIMARY KEY (fname, lname, email)
 10  );

Table created.

SQL> 
SQL> create table non_member_child(
  2    non_mem_fname VARCHAR(20) NOT NULL,
  3    non_mem_lname VARCHAR(20) NOT NULL,
  4    non_mem_email VARCHAR(20) NOT NULL,
  5    child_fname   VARCHAR(20) NOT NULL,
  6    child_lname   VARCHAR(20) NOT NULL,
  7    school_name   VARCHAR(20) NOT NULL,
  8    CONSTRAINT non_member_child_school_fk FOREIGN KEY (school_name)
  9  	 REFERENCES school(school_name),
 10    CONSTRAINT non_member_non_member_child_fk FOREIGN KEY (non_mem_fname,
 11  	 non_mem_lname, non_mem_email) REFERENCES non_member(fname, lname, email)
 12  );

Table created.

SQL> 
SQL> create table visitor(
  2    fname	     VARCHAR(20) NOT NULL, -- NOTE: maybe I should prefix this to avoid unwanted natural joins
  3    lname	     VARCHAR(20) NOT NULL,
  4    email	     VARCHAR(20) NOT NULL,
  5    meet_location VARCHAR(20) NOT NULL,
  6    meet_date     VARCHAR(20) NOT NULL,
  7    member_id     DECIMAL(7,0) NOT NULL,
  8    CONSTRAINT visitor_non_mem_fk FOREIGN KEY (fname, lname, email)
  9  	 REFERENCES non_member(fname, lname, email),
 10    CONSTRAINT visitor_meeting_fk FOREIGN KEY (meet_location, meet_date)
 11  	 REFERENCES meeting(meet_location, meet_date),
 12  	-- NOTE: This is a very big and complex primary key
 13    CONSTRAINT visitor_pk PRIMARY KEY (fname, lname, email, meet_date, meet_location)
 14    -- TODO: This relation needs two inclusion dependencies, likely deferrable until commit
 15  );

Table created.

