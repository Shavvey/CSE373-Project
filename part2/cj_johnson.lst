SQL> 
SQL> create table non_member_works_for(
  2    fname	      VARCHAR(20) NOT NULL, -- NOTE: Maybe I should prefix this to avoid unwanted natural joins
  3    lname	      VARCHAR(20) NOT NULL,
  4    email	      VARCHAR(20) NOT NULL,
  5    school_name    VARCHAR(20) NOT NULL,
  6    teach_sci_or_math VARCHAR(20) NOT NULL CHECK (teach_sci_or_math in ('science', 'math', 'both', 'none')),
  7    CONSTRAINT non_member_works_for_pk PRIMARY KEY (fname, lname, email),
  8    CONSTRAINT non_member_works_non_men FOREIGN KEY (school_name) REFERENCES school(school_name),
  9    CONSTRAINT non_member_works_non_mem FOREIGN KEY (fname, lname, email)
 10  	 REFERENCES non_member(fname, lname, email)
 11  );

Table created.

SQL> 
SQL> create table non_member_child(
  2    non_mem_fname VARCHAR(20) NOT NULL,
  3    non_mem_lname VARCHAR(20) NOT NULL,
  4    non_mem_email VARCHAR(20) NOT NULL,
  5    child_fname   VARCHAR(20) NOT NULL,
  6    child_lname   VARCHAR(20) NOT NULL,
  7    school_name   VARCHAR(20) NOT NULL,
  8    CONSTRAINT non_member_child_school_fk FOREIGN KEY (school_name)
  9  	 REFERENCES school(school_name),
 10    CONSTRAINT non_member_non_member_child_fk FOREIGN KEY (non_mem_fname,
 11  	 non_mem_lname, non_mem_email) REFERENCES non_member(fname, lname, email)
 12  );

Table created.

SQL> 
SQL> create table visitor(
  2    fname	     VARCHAR(20) NOT NULL, -- NOTE: maybe I should prefix this to avoid unwanted natural joins
  3    lname	     VARCHAR(20) NOT NULL,
  4    email	     VARCHAR(20) NOT NULL,
  5    meet_location VARCHAR(20) NOT NULL,
  6    meet_date     VARCHAR(20) NOT NULL,
  7    member_id     DECIMAL(7,0) NOT NULL,
  8    CONSTRAINT visitor_non_mem_fk FOREIGN KEY (fname, lname, email)
  9  	 REFERENCES non_member(fname, lname, email),
 10    CONSTRAINT visitor_meeting_fk FOREIGN KEY (meet_location, meet_date)
 11  	 REFERENCES meeting(meet_location, meet_date),
 12  	-- NOTE: This is a very big and complex primary key
 13    CONSTRAINT visitor_pk PRIMARY KEY (fname, lname, email, meet_date, meet_location)
 14    -- TODO: This relation needs two inclusion dependencies, likely deferrable until commit
 15  );

Table created.

SQL> 
SQL> -- STEP 2: Hoist triggers
SQL> @triggers
SQL> /**
SQL> * TRIGGER 1: Ensure that only a member in
SQL> * good standing can join the Board and also
SQL> * that there is never more than one president.
SQL> **/
SQL> CREATE OR REPLACE TRIGGER
  2    board_member_president_aiusd -- after insert or update, but before commit
  3  BEFORE INSERT OR UPDATE
  4  ON board_member
  5  REFERENCING NEW AS n
  6  for each row
  7  DECLARE
  8    mem_standing member.standing%type;
  9    r_count number;
 10  BEGIN
 11  -- Get standing
 12   SELECT standing INTO mem_standing
 13   FROM member
 14   WHERE :n.member_id = member.member_id;
 15    -- Trigger exception if president candidate is in poor standing
 16    IF (mem_standing = 'poor') THEN
 17  	 raise_application_error(-20001, 'Board member must be in good standing');
 18    END IF;
 19    IF (:n.role = 'president') THEN
 20  	 SELECT COUNT(*) INTO r_count
 21  	 FROM board_member
 22  	 WHERE role = :n.role;
 23  	 IF r_count > 0 THEN
 24  	   raise_application_error(-20002, 'Can only be one president');
 25  	 END IF;
 26    END IF;
 27  END;
 28  /

Trigger created.

SQL> show errors
No errors.
SQL> 
SQL> /**
SQL> * TRIGGER 2: If a person becoming a member for the first time had attended a public
SQL> * meeting in the past, then print a thank-you message for attendance on
SQL> * that date.
SQL> **/
SQL> CREATE OR REPLACE TRIGGER
  2    member_thank_you_aird
  3  AFTER INSERT
  4  ON member
  5  REFERENCING NEW as n
  6  for each row
  7  DECLARE
  8    CURSOR visitor_cursor IS SELECT fname, lname, email, meet_date FROM visitor;
  9    vis_fname visitor.fname%type;
 10    vis_lname visitor.lname%type;
 11    vis_email visitor.email%type;
 12    vis_meet_date visitor.meet_date%type;
 13  BEGIN
 14    OPEN visitor_cursor;
 15    LOOP
 16  	 FETCH visitor_cursor INTO vis_fname, vis_lname, vis_email, vis_meet_date;
 17  	 IF (:n.fname = vis_fname) AND (:n.lname = vis_lname)
 18  	   AND (:n.email = vis_email) THEN
 19  	   dbms_output.put_line('Thank you for attending meet on: ' || vis_meet_date);
 20  	 END IF;
 21  	 EXIT WHEN visitor_cursor%NOTFOUND;
 22    END LOOP;
 23    CLOSE visitor_cursor;
 24  END;
 25  /

Trigger created.

SQL> show errors
No errors.
