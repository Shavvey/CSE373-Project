SQL> -- STEP 3: Execute queries
SQL> @queries
SQL> /**
SQL> * CSE373 - Introduction to Databases - Project
SQL> * ============================================
SQL> * Name: Cole Johnson
SQL> * Due Date: 5/2/2026
SQL> *
SQL> * I certify that this assignment has been
SQL> * completed by myself.
SQL> **/
SQL> 
SQL> /**
SQL> * QUERY 1: Display the following group name and number of members:
SQL> * (i) parent but not educator, (ii) educator but not parent,
SQL> * and (iii) both a parent and an educator
SQL> **/
SQL> 
SQL> SELECT COUNT(*) AS "Parent But Not Educator Count" from (
  2    SELECT member_id from parent
  3    MINUS -- set difference
  4    SELECT member_id from educator
  5  );

Parent But Not Educator Count                                                   
-----------------------------                                                   
                            2                                                   

SQL> 
SQL> SELECT COUNT(*) AS "Educator But Not Parent Count" from (
  2    SELECT member_id from educator
  3    MINUS -- set difference
  4    SELECT member_id from parent
  5  );

Educator But Not Parent Count                                                   
-----------------------------                                                   
                            3                                                   

SQL> 
SQL> SELECT COUNT(*) AS "Both Parent and Eduator Count" from (
  2    SELECT member_id from member
  3    INTERSECT
  4    SELECT member_id from parent
  5    INTERSECT
  6    SELECT member_id from educator
  7  );

Both Parent and Eduator Count                                                   
-----------------------------                                                   
                            2                                                   

SQL> 
SQL> /**
SQL> * QUERY 2: Display the ID, first and last names, and membership
SQL> * expiration dates, of all the members whose member is going to expire within
SQL> * a month followed by those whose membershiop has
SQL> **/
SQL> 
SQL> SELECT * FROM (
  2    SELECT member_id, fname, lname,
  3  	 TRUNC(member_expr) - TRUNC(SYSDATE) as days, 'MONTH TO EXPIRY'
  4    FROM member
  5    )
  6  WHERE days > 0 and days < 30;

 MEMBER_ID FNAME                LNAME                      DAYS 'MONTHTOEXPIRY' 
---------- -------------------- -------------------- ---------- --------------- 
    900001 daniel               plainview                     9 MONTH TO EXPIRY 
    900003 gary                 garyson                      24 MONTH TO EXPIRY 
    900006 elizabeth            holmes                        3 MONTH TO EXPIRY 

SQL> 
SQL> SELECT * FROM (
  2    SELECT member_id, fname, lname,
  3  	 TRUNC(member_expr) - TRUNC(SYSDATE) as days, 'EXPIRED'
  4    FROM member
  5    )
  6  WHERE days < 0;

 MEMBER_ID FNAME                LNAME                      DAYS 'EXPIRE         
---------- -------------------- -------------------- ---------- -------         
    900002 royal                tennenbaum                  -31 EXPIRED         

SQL> 
SQL> /**
SQL> * QUERY 3: list the ID, first, and last names of members who are (current or former)
SQL> * teachers of science / math as well as parent and teach at a school
SQL> * attended by one or more of their children. (If a teacher has only one
SQL> * child, then that child must attend; if a teacher has two children, then both must attend.)
SQL> **/
SQL> 
SQL> -- NOTE: This is messy maybe rewrite with natural join?
SQL> SELECT m.member_id, fname, lname, e.teach_sci_or_math
  2  FROM educator e, member m
  3  WHERE e.school_name = all
  4    (SELECT mc.school_name
  5  	FROM member_child mc
  6  	WHERE mc.member_id = e.member_id
  7    )
  8  AND (e.teach_sci_or_math != 'none') -- Must teach at least one
  9  AND (e.member_id = m.member_id);

 MEMBER_ID FNAME                LNAME                TEACH_SCI_OR_MATH          
---------- -------------------- -------------------- --------------------       
    900005 cole                 coleson              science                    
    900006 elizabeth            holmes               math                       

SQL> 
SQL> /**
SQL> * QUERY 4: if either two members have the same first name, last name, and email
SQL> * address, or a non-member and a member share those three items, then
SQL> * print those three items for each pair; add a string BOTH MEMBERS
SQL> * in the first case and ONE NON-MEMBER in the other. The items for
SQL> * BOTH-MEMBERS should appear first ordered by first name followed
SQL> * by the rest ordered similarly.
SQL> **/
SQL> 
SQL> SELECT fname, lname, email, 'ONE MEMBER'
  2  FROM member m
  3  WHERE EXISTS
  4    (SELECT *
  5    FROM non_member nm
  6    WHERE nm.fname = m.fname
  7    AND nm.lname = m.lname
  8    AND nm.email = m.email
  9    )
 10  UNION ALL
 11  SELECT fname, lname, email, 'BOTH MEMBER'
 12  FROM member m1
 13  WHERE EXISTS
 14    (SELECT *
 15    FROM member m2
 16    WHERE m1.fname = m2.fname
 17    AND m1.lname = m2.lname
 18    AND m1.email = m2.email
 19    AND m1.member_id != m2.member_id
 20    );

FNAME                LNAME                EMAIL                                 
-------------------- -------------------- ------------------------------        
'ONEMEMBER'                                                                     
-----------                                                                     
elizabeth            holmes               eholmes@theranos.com                  
ONE MEMBER                                                                      
                                                                                
cole                 coleson              cole@c.com                            
BOTH MEMBER                                                                     
                                                                                
cole                 coleson              cole@c.com                            
BOTH MEMBER                                                                     
                                                                                

