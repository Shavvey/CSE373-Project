SQL> create table non_member(
  2    fname	      VARCHAR(20) NOT NULL, -- NOTE: Maybe I should prefix this to avoid unwanted natural joins
  3    lname	      VARCHAR(20) NOT NULL,
  4    email	      VARCHAR(20) NOT NULL,
  5    zip	      DECIMAL(5,0) NOT NULL, -- NOTE: VARCHAR might also be acceptable, but decimal is easier for comparison
  6    street	      VARCHAR(20) NOT NULL,
  7    city	      VARCHAR(20) NOT NULL,
  8    date_of_record DATE NOT NULL, -- NOTE: When we first learned this info
  9    CONSTRAINT non_member_pk PRIMARY KEY (fname, lname, email)
 10  );

Table created.

